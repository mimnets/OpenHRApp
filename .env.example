# ============================================================
# OpenHR — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Required: Supabase Backend ---
# Create a project at https://supabase.com (free tier) or use your
# self-hosted Supabase instance. Get these from:
#   Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Optional: Web Push Notifications ---
# Generate a VAPID key pair for browser push notifications:
#   npx web-push generate-vapid-keys
# Or generate via: https://vapidkeys.com
VITE_VAPID_PUBLIC_KEY=
